<div id="wak" class="layout layout--col layout--center m--0 bg--white wakquarter">

 <div class="flex flex--col w--full xh--full flex--content-center flex--center-x gap--none">
  <img class="image m--2 w--12" src="data:image/svg+xml;base64,">
  <p class="font spacetop">The next Apple keynote:</p>
  <h1 class="font spacebottom m--3">{{ keynote.event_name }}</h1>
  <p class="font spacetop">this event will be held on:</p>  
  <h1 class="font spacebottom m--3">
{{ keynote.internationaldate | date: "%s" | plus: trmnl.user.utc_offset | date: "%A, %B %d" }}
at
{{ keynote.internationaldate | date: "%s" | plus: trmnl.user.utc_offset | date: "%H<sup>%M</sup>" }}  </h1> 
 </div>
 <div class="box pt--3 mt--3">
  <p class="font spacetop">Time remaining:</p>
 </div>
 <div class="flex flex--row w--full flex--content-center flex--center-x gap--none">
  <div class="box px--6 text--center"> 
   {% if days >= 1 %}
   <h1 class="font">{{ days }}</h1>
    {% if days == 1 %}
     <p class="font">day</p>
    {% else %}
     <p class="font">days</p>
    {% endif %}
   {% endif %}
  </div>
  <div class="box px--6 text--center"> 
   <h1 class="font">{{ hours }}</h1>
    {% if hours == 1 %}
     <p class="font">hour</p>
    {% else %}
     <p class="font">hours</p>
    {% endif %}
  </div>
  <div class="box px--6 text--center"> 
   <h1 class="font">{{ minutes }}</h1>
    {% if minutes == 1 %}
     <p class="font">minute</p>
    {% else %}
     <p class="font">minutes</p>
    {% endif %}
  </div>
 </div>
  
</div>